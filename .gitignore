# Ignore node_modules everywhere
**/node_modules/

# Ignore local env files everywhere
**/.env
**/.env.local
**/.env.development.local
**/.env.test.local
**/.env.production.local

# Logs
**/npm-debug.log*
**/yarn-debug.log*
**/yarn-error.log*

# OS metadata
**/.DS_Store
**/Thumbs.db

# Exclude docs directory completely (contains markdown files and images we don't want to push)
docs/

# Exclude all markdown files except README.md anywhere in the repo
**/*.md
!**/README.md
