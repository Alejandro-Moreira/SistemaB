PORT=3003
ALLOWED_ORIGIN=http://localhost:3002

# Mode: 'mock' (local node:crypto mock) or 'aws' (real AWS KMS / LocalStack)
KMS_MODE=mock

# AWS / LocalStack KMS Configurations (Uncomment and configure if using KMS_MODE=aws)
# AWS_REGION=us-east-1
# AWS_ACCESS_KEY_ID=your_access_key_id
# AWS_SECRET_ACCESS_KEY=your_secret_access_key
# KMS_KEY_ARN=arn:aws:kms:us-east-1:123456789012:key/your-key-id
# KMS_ENDPOINT=http://localhost:4566

# Keycloak Configurations (for verifying JWT signatures)
KEYCLOAK_URL=http://localhost:8080
KEYCLOAK_REALM=facturacion-realm
